{{!
    Mobile chat template for the Moodle app.
    Uses Ionic components and Angular directives.

    @package    local_ai_course_assistant
    @copyright  2025 AI Course Assistant
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}

<div class="aica-mobile-chat">
    {{! Welcome message when no history }}
    <div *ngIf="!messages || messages.length === 0" class="aica-mobile-welcome">
        <div class="aica-mobile-welcome-icon">
            <ion-icon name="school-outline" style="font-size: 48px; color: var(--core-color);"></ion-icon>
        </div>
        <h2>{{ "plugin.local_ai_course_assistant.mobile_welcome" | translate:{$a: "{{firstname}}"} }}</h2>
        <p>{{ "plugin.local_ai_course_assistant.mobile_welcome_sub" | translate }}</p>
        <div class="aica-mobile-chips">
            <ion-chip (click)="sendChip('What are the key concepts in this course?')" color="primary" outline="true">
                <ion-icon name="bulb-outline"></ion-icon>
                <ion-label>{{ "plugin.local_ai_course_assistant.mobile_chip_concepts" | translate }}</ion-label>
            </ion-chip>
            <ion-chip (click)="sendChip('Help me create a study plan')" color="primary" outline="true">
                <ion-icon name="calendar-outline"></ion-icon>
                <ion-label>{{ "plugin.local_ai_course_assistant.mobile_chip_studyplan" | translate }}</ion-label>
            </ion-chip>
            <ion-chip (click)="sendChip('Quiz me on this course')" color="primary" outline="true">
                <ion-icon name="flash-outline"></ion-icon>
                <ion-label>{{ "plugin.local_ai_course_assistant.mobile_chip_quiz" | translate }}</ion-label>
            </ion-chip>
        </div>
    </div>

    {{! Message list }}
    <div class="aica-mobile-messages">
        <div *ngFor="let msg of messages" class="aica-mobile-msg" [class.aica-mobile-msg--user]="msg.role === 'user'" [class.aica-mobile-msg--assistant]="msg.role === 'assistant'">
            <div class="aica-mobile-msg-bubble">
                <core-format-text [text]="msg.message" [filter]="false"></core-format-text>
                <span class="aica-mobile-msg-time" *ngIf="msg.time">{{ msg.time }}</span>
            </div>
        </div>

        {{! Typing indicator }}
        <div *ngIf="sending" class="aica-mobile-msg aica-mobile-msg--assistant">
            <div class="aica-mobile-msg-bubble aica-mobile-typing">
                <span></span><span></span><span></span>
            </div>
        </div>
    </div>

    {{! Input area }}
    <div class="aica-mobile-input">
        <ion-textarea
            [(ngModel)]="userInput"
            placeholder="{{ 'plugin.local_ai_course_assistant.mobile_placeholder' | translate }}"
            rows="1"
            autoGrow="true"
            (keyup.enter)="sendMessage()"
            [disabled]="sending">
        </ion-textarea>
        <ion-button (click)="sendMessage()" [disabled]="sending || !userInput?.trim()" fill="clear" size="small">
            <ion-icon name="send" slot="icon-only"></ion-icon>
        </ion-button>
    </div>

    {{! Clear history button }}
    <div class="aica-mobile-footer" *ngIf="messages && messages.length > 0">
        <ion-button (click)="clearHistory()" fill="clear" size="small" color="medium">
            <ion-icon name="trash-outline" slot="start"></ion-icon>
            {{ "plugin.local_ai_course_assistant.mobile_clear" | translate }}
        </ion-button>
    </div>
</div>

<style>
.aica-mobile-chat {
    display: flex;
    flex-direction: column;
    min-height: 300px;
    padding: 8px;
}
.aica-mobile-welcome {
    text-align: center;
    padding: 32px 16px;
}
.aica-mobile-welcome-icon {
    margin-bottom: 12px;
}
.aica-mobile-welcome h2 {
    font-size: 20px;
    margin: 0 0 8px;
}
.aica-mobile-welcome p {
    color: var(--text-color, #666);
    font-size: 14px;
    margin: 0 0 16px;
}
.aica-mobile-chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
}
.aica-mobile-messages {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0;
}
.aica-mobile-msg {
    display: flex;
    margin-bottom: 8px;
}
.aica-mobile-msg--user {
    justify-content: flex-end;
}
.aica-mobile-msg--assistant {
    justify-content: flex-start;
}
.aica-mobile-msg-bubble {
    max-width: 80%;
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 15px;
    line-height: 1.4;
    position: relative;
}
.aica-mobile-msg--user .aica-mobile-msg-bubble {
    background: var(--core-color, #023e8a);
    color: #fff;
    border-bottom-right-radius: 4px;
}
.aica-mobile-msg--assistant .aica-mobile-msg-bubble {
    background: var(--gray-100, #f0f0f0);
    color: var(--text-color, #333);
    border-bottom-left-radius: 4px;
}
.aica-mobile-msg-time {
    display: block;
    font-size: 11px;
    opacity: 0.6;
    margin-top: 4px;
}
.aica-mobile-typing span {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #999;
    margin: 0 2px;
    animation: aica-typing-bounce 1.4s infinite ease-in-out both;
}
.aica-mobile-typing span:nth-child(1) { animation-delay: -0.32s; }
.aica-mobile-typing span:nth-child(2) { animation-delay: -0.16s; }
@keyframes aica-typing-bounce {
    0%, 80%, 100% { transform: scale(0.6); }
    40% { transform: scale(1); }
}
.aica-mobile-input {
    display: flex;
    align-items: flex-end;
    gap: 4px;
    padding: 8px 0;
    border-top: 1px solid var(--gray-200, #e0e0e0);
}
.aica-mobile-input ion-textarea {
    flex: 1;
    --padding-start: 12px;
    --padding-end: 12px;
    --padding-top: 8px;
    --padding-bottom: 8px;
    --background: var(--gray-100, #f0f0f0);
    border-radius: 20px;
    max-height: 120px;
}
.aica-mobile-footer {
    text-align: center;
    padding: 4px 0;
}
</style>
