{{!
    @template local_ai_course_assistant/emergency_admin

    v6.1.0 web emergency panel — per-subsystem kill switches mirroring the
    emergency_disable.php CLI flags. Each card shows current state and a
    disable (with confirm checkbox + reason) or restore form.

    Context variables required for this template:
    * rows - array of {flag, label, description, disabled, is_all}
    * sesskey - the session key for the POST forms
    * actionurl - this page's URL
    * settings_url - link back to the main plugin settings
    * cli_path - the equivalent CLI invocation, shown as reference

    Example context (json):
    {
        "rows": [
            {"flag": "chat", "label": "Chat", "description": "Blocks chat traffic", "disabled": false, "is_all": false}
        ],
        "sesskey": "abc123",
        "actionurl": "#",
        "settings_url": "#",
        "cli_path": "php local/ai_course_assistant/admin/cli/emergency_disable.php"
    }
}}
<div class="local-aica-emergency container-fluid px-0">

    <div class="mb-3">
        <a href="{{settings_url}}" class="btn btn-sm btn-outline-secondary">&larr; {{#str}} emergency:back_to_settings, local_ai_course_assistant {{/str}}</a>
    </div>

    <div class="alert alert-warning" role="alert">
        {{#str}} emergency:page_warning, local_ai_course_assistant {{/str}}
    </div>

    <div class="row">
        {{#rows}}
        <div class="col-12 col-md-6 col-xl-4 mb-3">
            <div class="card h-100 {{#is_all}}border-danger{{/is_all}} {{#disabled}}bg-light{{/disabled}}">
                <div class="card-body">
                    <h5 class="card-title d-flex align-items-center justify-content-between">
                        {{label}}
                        {{#disabled}}
                        <span class="badge badge-danger">{{#str}} emergency:state_disabled, local_ai_course_assistant {{/str}}</span>
                        {{/disabled}}
                        {{^disabled}}
                        <span class="badge badge-success">{{#str}} emergency:state_active, local_ai_course_assistant {{/str}}</span>
                        {{/disabled}}
                    </h5>
                    <p class="card-text small text-muted">{{description}}</p>

                    {{^disabled}}
                    <form method="post" action="{{actionurl}}" class="mt-2">
                        <input type="hidden" name="sesskey" value="{{sesskey}}">
                        <input type="hidden" name="action" value="disable">
                        <input type="hidden" name="flag" value="{{flag}}">
                        <div class="form-group mb-2">
                            <input type="text" name="reason" class="form-control form-control-sm"
                                   placeholder="{{#str}} emergency:reason_placeholder, local_ai_course_assistant {{/str}}"
                                   aria-label="{{#str}} emergency:reason_placeholder, local_ai_course_assistant {{/str}}">
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="confirm" value="1" id="confirm-{{flag}}">
                            <label class="form-check-label small" for="confirm-{{flag}}">
                                {{#str}} emergency:confirm_label, local_ai_course_assistant {{/str}}
                            </label>
                        </div>
                        <button type="submit" class="btn btn-sm {{#is_all}}btn-danger{{/is_all}}{{^is_all}}btn-outline-danger{{/is_all}}">
                            {{#str}} emergency:disable_button, local_ai_course_assistant {{/str}}
                        </button>
                    </form>
                    {{/disabled}}

                    {{#disabled}}
                    <form method="post" action="{{actionurl}}" class="mt-2">
                        <input type="hidden" name="sesskey" value="{{sesskey}}">
                        <input type="hidden" name="action" value="restore">
                        <input type="hidden" name="flag" value="{{flag}}">
                        <button type="submit" class="btn btn-sm btn-success">
                            {{#str}} emergency:restore_button, local_ai_course_assistant {{/str}}
                        </button>
                    </form>
                    {{/disabled}}
                </div>
            </div>
        </div>
        {{/rows}}
    </div>

    <div class="mt-3 small text-muted">
        <p>{{#str}} emergency:cli_reference, local_ai_course_assistant {{/str}} <code>{{cli_path}}</code></p>
    </div>
</div>
