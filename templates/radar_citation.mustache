{{!
    @template local_ai_course_assistant/radar_citation

    Learning Radar citation popover. Replaces innerHTML string-building in
    amd/src/learning_radar.js (CONTRIB-10574 #94); Mustache auto-escapes every
    field, so no manual escaping is needed.

    Context variables required for this template:
    * who - pseudonymized author label
    * course - course full name
    * date - formatted timestamp
    * message - message text (already truncated by the caller)

    Example context (json):
    { "who": "Learner 7", "course": "BUS101", "date": "2026-06-17 09:00", "message": "What is osmosis?" }
}}
<div class="local-ai-course-assistant__cite-head"><strong>{{who}}</strong> <span class="text-muted">{{course}} &middot; {{date}}</span></div>
<div class="local-ai-course-assistant__cite-body">{{message}}</div>
<div class="text-end mt-2"><button type="button" class="btn btn-sm btn-link p-0" data-action="radar-cite-close">{{#str}}closebuttontitle, moodle{{/str}}</button></div>
