{{!
    @template local_ai_course_assistant/analytics_message

    A status message for an analytics pane. Replaces innerHTML string-building
    for the error / empty states in amd/src/analytics_dashboard.js
    (CONTRIB-10574 #94). Mustache auto-escapes the message.

    Context variables required for this template:
    * danger - boolean, true to render a danger alert, false for a muted note
    * message - the text to display

    Example context (json):
    { "danger": true, "message": "Error loading data" }
}}
{{#danger}}<div class="alert alert-danger">{{message}}</div>{{/danger}}
{{^danger}}<p class="text-muted">{{message}}</p>{{/danger}}
